{
  "routes": [
    {
      "route": "/articles/*",
      "serve": "/articles.html",
      "statusCode": 200
    },
    {
      "route": "/*",
      "redirect": "https://www.intervallumlabs.com",
      "statusCode": 301
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  }
}
